import React, { useState, useEffect, useRef, FormEvent } from "react";
import { motion, AnimatePresence } from "motion/react";
import {
  Activity,
  ChevronLeft,
  ChevronRight,
  Trash2,
  CheckCircle2,
  XCircle,
  HelpCircle,
  Mic,
  MicOff,
  Volume2,
  CloudUpload,
  Moon,
  Sun,
  User,
  Info,
  AlertTriangle,
  X,
  BookOpen,
  Headphones,
  Sparkles,
  RefreshCw,
  Award
} from "lucide-react";
import { Exercise, ScoreState, StudentProfile } from "./types";
import { buildExercises } from "./data";

export default function App() {
  // --- React State ---
  const [exercises, setExercises] = useState<Exercise[]>([]);
  const [currentIndex, setCurrentIndex] = useState<number>(0);
  const [score, setScore] = useState<ScoreState>({
    grammar: {},
    questions: {},
    shadowing: {}
  });

  const [activeTab, setActiveTab] = useState<"grammar" | "questions" | "shadowing">("grammar");
  const [student, setStudent] = useState<StudentProfile>({
    name: "Estudiante Invitado",
    email: "invitado@aula.com",
    isAuthenticated: false
  });

  // Theme state
  const [darkMode, setDarkMode] = useState<boolean>(false);

  // Input states
  const [grammarInput, setGrammarInput] = useState<string>("");
  const [questionInput, setQuestionInput] = useState<string>("");

  // Verification states
  const [grammarChecked, setGrammarChecked] = useState<boolean>(false);
  const [questionChecked, setQuestionChecked] = useState<boolean>(false);

  const [grammarFeedback, setGrammarFeedback] = useState<{
    status: "success" | "warning" | "error" | null;
    title: string;
    desc: string;
  }>({ status: null, title: "", desc: "" });

  const [questionFeedback, setQuestionFeedback] = useState<{
    status: "success" | "error" | null;
    title: string;
    desc: string;
  }>({ status: null, title: "", desc: "" });

  // Shadowing & dictation states
  const [speechSpeed, setSpeechSpeed] = useState<number>(1.0);
  const [isRecordingSpeech, setIsRecordingSpeech] = useState<boolean>(false);
  const [speechLiveOutput, setSpeechLiveOutput] = useState<string>("");
  const [shadowingResult, setShadowingResult] = useState<{
    percent: number | null;
    status: "excellent" | "good" | "retry" | "manual" | null;
    title: string;
    desc: string;
  }>({ percent: null, status: null, title: "", desc: "" });

  // Dictation states
  const [activeDictationInput, setActiveDictationInput] = useState<"grammar" | "question" | null>(null);

  // UI overlays & effects
  const [showLoginModal, setShowLoginModal] = useState<boolean>(false);
  const [showResetModal, setShowResetModal] = useState<boolean>(false);
  const [showSheetsGuideModal, setShowSheetsGuideModal] = useState<boolean>(false);
  const [manualName, setManualName] = useState<string>("");
  const [manualEmail, setManualEmail] = useState<string>("");
  const [isSyncing, setIsSyncing] = useState<boolean>(false);

  // Toast notifications state
  const [toast, setToast] = useState<{
    message: string;
    type: "success" | "error" | "warning" | "info" | null;
  }>({ message: "", type: null });

  // Image resolver state for extensions fallback
  const EXTENSIONS = ["png", "jpg", "jpeg", "webp", "PNG", "JPG", "JPEG"];
  const [imageExtIndex, setImageExtIndex] = useState<number>(0);
  const [imageLoadFailed, setImageLoadFailed] = useState<boolean>(false);

  // Refs for Speech Recognition instances
  const recognitionRef = useRef<any>(null);
  const dictationRef = useRef<any>(null);
  const toastTimeoutRef = useRef<NodeJS.Timeout | null>(null);

  // --- Initial Setup and LocalStorage Sync ---
  useEffect(() => {
    // 1. Build and set randomized exercises
    const list = buildExercises();
    setExercises(list);

    // 2. Load Student Info
    const storedName = localStorage.getItem("studentName");
    const storedEmail = localStorage.getItem("studentEmail");
    if (storedName && storedEmail) {
      setStudent({
        name: storedName,
        email: storedEmail,
        isAuthenticated: true
      });
    }

    // 3. Load Progress
    const savedIndex = localStorage.getItem("presentContinuous_currentIndex");
    const savedScore = localStorage.getItem("presentContinuous_score");
    if (savedIndex !== null) {
      setCurrentIndex(parseInt(savedIndex, 10));
    }
    if (savedScore !== null) {
      try {
        setScore(JSON.parse(savedScore));
      } catch (e) {
        console.error("Error parsing saved score:", e);
      }
    }

    // 4. Set Dark Mode
    const savedTheme = localStorage.getItem("theme");
    const isDark =
      savedTheme === "dark" ||
      (!savedTheme && window.matchMedia("(prefers-color-scheme: dark)").matches);
    setDarkMode(isDark);
    if (isDark) {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }

    // 5. Initialize browser SpeechRecognition
    initSpeechRecognition();
  }, []);

  // Sync index and scores to localStorage when updated
  useEffect(() => {
    localStorage.setItem("presentContinuous_currentIndex", currentIndex.toString());
    localStorage.setItem("presentContinuous_score", JSON.stringify(score));
  }, [currentIndex, score]);

  // Reset image extension index when exercise changes
  useEffect(() => {
    setImageExtIndex(0);
    setImageLoadFailed(false);
    resetTabStates();
  }, [currentIndex]);

  // Handle system dark mode updates
  const toggleDarkMode = () => {
    const nextDark = !darkMode;
    setDarkMode(nextDark);
    if (nextDark) {
      document.documentElement.classList.add("dark");
      localStorage.setItem("theme", "dark");
    } else {
      document.documentElement.classList.remove("dark");
      localStorage.setItem("theme", "light");
    }
  };

  // --- Toast Trigger helper ---
  const showToast = (message: string, type: "success" | "error" | "warning" | "info" = "info") => {
    if (toastTimeoutRef.current) {
      clearTimeout(toastTimeoutRef.current);
    }
    setToast({ message, type });
    toastTimeoutRef.current = setTimeout(() => {
      setToast({ message: "", type: null });
    }, 4000);
  };

  // --- Reset Tab states on transition ---
  const resetTabStates = () => {
    setGrammarInput("");
    setQuestionInput("");
    setGrammarChecked(false);
    setQuestionChecked(false);
    setGrammarFeedback({ status: null, title: "", desc: "" });
    setQuestionFeedback({ status: null, title: "", desc: "" });
    setShadowingResult({ percent: null, status: null, title: "", desc: "" });
    setSpeechLiveOutput("");
    stopSpeechRecording();
    stopDictationRecording();
  };

  // --- Web Speech API: Initialization ---
  const initSpeechRecognition = () => {
    const SpeechRecognition =
      (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SpeechRecognition) {
      console.warn("SpeechRecognition not supported in this browser.");
      return;
    }

    // Recognition for Shadowing evaluation
    const rec = new SpeechRecognition();
    rec.continuous = false;
    rec.lang = "en-US";
    rec.interimResults = false;
    rec.maxAlternatives = 1;

    rec.onstart = () => {
      setIsRecordingSpeech(true);
      setSpeechLiveOutput("");
      setShadowingResult({ percent: null, status: null, title: "", desc: "" });
    };

    rec.onresult = (event: any) => {
      const resultText = event.results[0][0].transcript;
      setSpeechLiveOutput(`Escuchado: "${resultText}"`);
      evaluateSpeechAccuracy(resultText);
    };

    rec.onerror = (event: any) => {
      console.error("Speech Recognition error:", event.error);
      setIsRecordingSpeech(false);
      if (event.error === "not-allowed") {
        showToast("Permiso de micrófono denegado. Permite el acceso para continuar.", "error");
      } else {
        showToast("No se pudo detectar la voz. Por favor, intenta de nuevo.", "warning");
      }
    };

    rec.onend = () => {
      setIsRecordingSpeech(false);
    };

    recognitionRef.current = rec;

    // Recognition for dictation
    const dict = new SpeechRecognition();
    dict.continuous = false;
    dict.lang = "en-US";
    dict.interimResults = false;
    dict.maxAlternatives = 1;

    dict.onstart = () => {
      showToast("Escuchando... Dicta en inglés.", "info");
    };

    dict.onresult = (event: any) => {
      const text = event.results[0][0].transcript;
      if (activeDictationInput === "grammar") {
        setGrammarInput(text);
      } else if (activeDictationInput === "question") {
        setQuestionInput(text);
      }
      showToast("Texto dictado con éxito.", "success");
    };

    dict.onerror = (event: any) => {
      console.error("Dictation error:", event.error);
      setActiveDictationInput(null);
      if (event.error === "not-allowed") {
        showToast("Micrófono bloqueado. Permite acceso en el navegador.", "error");
      } else {
        showToast("No se escuchó claramente. Intenta otra vez.", "warning");
      }
    };

    dict.onend = () => {
      setActiveDictationInput(null);
    };

    dictationRef.current = dict;
  };

  // --- Dictation controllers ---
  const toggleDictation = (inputTarget: "grammar" | "question") => {
    if (!dictationRef.current) {
      showToast("Tu navegador no soporta entrada de voz por dictado.", "warning");
      return;
    }

    if (activeDictationInput === inputTarget) {
      stopDictationRecording();
      return;
    }

    // Cancel text-to-speech outputs
    window.speechSynthesis.cancel();
    // Stop other records
    stopSpeechRecording();
    stopDictationRecording();

    setActiveDictationInput(inputTarget);
    try {
      dictationRef.current.start();
    } catch (e) {
      console.error("Failed to start dictation:", e);
    }
  };

  const stopDictationRecording = () => {
    if (dictationRef.current && activeDictationInput) {
      dictationRef.current.stop();
    }
    setActiveDictationInput(null);
  };

  // --- Shadowing: Text to Speech (Model) ---
  const speakModelTargetPhrase = () => {
    const ex = exercises[currentIndex];
    if (!ex) return;

    window.speechSynthesis.cancel(); // Stop pre-existing outputs
    const utterance = new SpeechSynthesisUtterance(ex.shadowingPhrase);
    utterance.lang = "en-US";
    utterance.rate = speechSpeed;
    window.speechSynthesis.speak(utterance);
  };

  const speakPronunciationAdvice = () => {
    const ex = exercises[currentIndex];
    if (!ex) return;

    const contraction = ex.pronoun === "she" ? "she's" : ex.pronoun === "he" ? "he's" : "they're";
    const textToSay = `To make the sound correctly, say first the pronoun with contracting verb: ${contraction}. Then pronounce clearly the verb with ending i n g.`;

    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(textToSay);
    utterance.lang = "en-US";
    utterance.rate = 0.85;
    window.speechSynthesis.speak(utterance);
  };

  // --- Shadowing: Speech Recording ---
  const toggleSpeechRecording = () => {
    if (!recognitionRef.current) {
      // Fallback manual evaluation
      setShadowingResult({
        percent: null,
        status: "manual",
        title: "Autoevaluación de Pronunciación",
        desc: "El reconocimiento de voz en tiempo real no está activo en este navegador o sistema operativo."
      });
      return;
    }

    if (isRecordingSpeech) {
      stopSpeechRecording();
    } else {
      window.speechSynthesis.cancel();
      stopDictationRecording();
      try {
        recognitionRef.current.start();
      } catch (e) {
        console.error("Failed starting speech recognition:", e);
      }
    }
  };

  const stopSpeechRecording = () => {
    if (recognitionRef.current && isRecordingSpeech) {
      recognitionRef.current.stop();
    }
    setIsRecordingSpeech(false);
  };

  // --- String similarity engine ---
  const cleanString = (str: string): string => {
    return str
      .toLowerCase()
      .trim()
      .replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g, "")
      .replace(/\s+/g, " ");
  };

  const editDistance = (s1: string, s2: string): number => {
    const str1 = s1.toLowerCase();
    const str2 = s2.toLowerCase();

    const costs: number[] = [];
    for (let i = 0; i <= str1.length; i++) {
      let lastValue = i;
      for (let j = 0; j <= str2.length; j++) {
        if (i === 0) {
          costs[j] = j;
        } else {
          if (j > 0) {
            let newValue = costs[j - 1];
            if (str1.charAt(i - 1) !== str2.charAt(j - 1)) {
              newValue = Math.min(Math.min(newValue, lastValue), costs[j]) + 1;
            }
            costs[j - 1] = lastValue;
            lastValue = newValue;
          }
        }
      }
      if (i > 0) {
        costs[str2.length] = lastValue;
      }
    }
    return costs[str2.length];
  };

  const calculateSimilarity = (s1: string, s2: string): number => {
    let longer = s1;
    let shorter = s2;
    if (s1.length < s2.length) {
      longer = s2;
      shorter = s1;
    }
    const longerLength = longer.length;
    if (longerLength === 0) {
      return 1.0;
    }
    return (longerLength - editDistance(longer, shorter)) / parseFloat(longerLength.toString());
  };

  const evaluateSpeechAccuracy = (spokenText: string) => {
    const ex = exercises[currentIndex];
    if (!ex) return;

    const cleanTarget = cleanString(ex.shadowingPhrase);
    const cleanSpoken = cleanString(spokenText);

    const scorePercent = Math.round(calculateSimilarity(cleanTarget, cleanSpoken) * 100);

    // Save shadowing score
    const updatedShadowing = { ...score.shadowing, [currentIndex]: scorePercent };
    const nextScore = { ...score, shadowing: updatedShadowing };
    setScore(nextScore);

    if (scorePercent >= 85) {
      setShadowingResult({
        percent: scorePercent,
        status: "excellent",
        title: "¡Excelente pronunciación!",
        desc: "Tu ritmo, entonación y palabras coinciden perfectamente con el modelo de audio."
      });
      showToast("¡Pronunciación fantástica!", "success");
    } else if (scorePercent >= 60) {
      setShadowingResult({
        percent: scorePercent,
        status: "good",
        title: "Buen intento, sigue practicando",
        desc: "Estás cerca de la meta. Prueba ralentizando el audio guía a 0.75x y practica la contracción."
      });
    } else {
      setShadowingResult({
        percent: scorePercent,
        status: "retry",
        title: "Podemos mejorarlo",
        desc: "Haz clic en el altavoz para oírlo lento y repítelo de nuevo con fuerza."
      });
    }

    // Auto sync to cloud if registered student
    if (student.isAuthenticated) {
      syncProgressToSheets(nextScore, currentIndex, student);
    }
  };

  // Handle manual shadowing fallback grading
  const handleManualShadowingGrade = (percent: number) => {
    const updatedShadowing = { ...score.shadowing, [currentIndex]: percent };
    const nextScore = { ...score, shadowing: updatedShadowing };
    setScore(nextScore);

    setShadowingResult({
      percent: percent,
      status: "excellent",
      title: "Puntuación de voz registrada",
      desc: `Registrado manualmente: ${percent}% Match local.`
    });

    if (student.isAuthenticated) {
      syncProgressToSheets(nextScore, currentIndex, student);
    }
  };

  // --- Tab 1: Verification Logic ---
  const handleVerifyGrammar = () => {
    if (grammarChecked) {
      // Act as "Next Exercise" button
      handleNextExercise();
      return;
    }

    const ex = exercises[currentIndex];
    if (!ex) return;

    if (!grammarInput.trim()) {
      showToast("Por favor, escribe una respuesta primero.", "warning");
      return;
    }

    const inputCleaned = cleanString(grammarInput);
    const targetCleanedPrimary = cleanString(ex.grammarAnswerPrimary);
    const targetCleanedFull = cleanString(ex.grammarAnswerFull);

    let nextGrammarScore = false;
    let feedbackStatus: "success" | "warning" | "error" = "error";
    let title = "";
    let desc = "";

    if (inputCleaned === targetCleanedPrimary) {
      nextGrammarScore = true;
      feedbackStatus = "success";
      title = "¡Excelente respuesta!";
      desc = `Correcto. Has formulado la respuesta con la contracción ideal: "${ex.grammarAnswerPrimary}"`;
      showToast("¡Gramática perfecta!", "success");
    } else if (inputCleaned === targetCleanedFull) {
      nextGrammarScore = false; // Contraction mandatory
      feedbackStatus = "warning";
      title = "¡Casi correcto!";
      desc = `Tu gramática es buena, pero en este nivel debes practicar la contracción activa. La respuesta esperada es: "${ex.grammarAnswerPrimary}"`;
    } else {
      nextGrammarScore = false;
      feedbackStatus = "error";
      title = "Estructura incorrecta";
      desc = `Recuerda construir usando sujeto, verbo 'to be' conjugado, y acción con terminación '-ing'. Forma correcta sugerida: "${ex.grammarAnswerPrimary}"`;
      showToast("Revisa la estructura gramatical.", "error");
    }

    const updatedGrammar = { ...score.grammar, [currentIndex]: nextGrammarScore };
    const nextScore = { ...score, grammar: updatedGrammar };
    setScore(nextScore);
    setGrammarChecked(true);
    setGrammarFeedback({ status: feedbackStatus, title, desc });

    if (student.isAuthenticated) {
      syncProgressToSheets(nextScore, currentIndex, student);
    }
  };

  // --- Tab 2: Verification Logic ---
  const handleVerifyQuestion = () => {
    if (questionChecked) {
      handleNextExercise();
      return;
    }

    const ex = exercises[currentIndex];
    if (!ex) return;

    if (!questionInput.trim()) {
      showToast("Por favor, escribe una pregunta primero.", "warning");
      return;
    }

    const inputCleaned = cleanString(questionInput);
    const targetCleaned = cleanString(ex.questionAnswerPrimary);

    let nextQuestionScore = false;
    let feedbackStatus: "success" | "error" = "error";
    let title = "";
    let desc = "";

    if (inputCleaned === targetCleaned) {
      nextQuestionScore = true;
      feedbackStatus = "success";
      title = "¡Excelente Pregunta!";
      desc = `Has formulado la pregunta perfectamente: "${ex.questionAnswerPrimary}"`;
      showToast("¡Pregunta excelente!", "success");
    } else {
      nextQuestionScore = false;
      feedbackStatus = "error";
      title = "Estructura incorrecta";
      desc = `Para preguntas de sí/no, antepone el verbo conjugado (Am/Is/Are), luego el pronombre y por último la acción con '-ing'. Forma esperada: "${ex.questionAnswerPrimary}"`;
      showToast("Revisa la estructura de la pregunta.", "error");
    }

    const updatedQuestions = { ...score.questions, [currentIndex]: nextQuestionScore };
    const nextScore = { ...score, questions: updatedQuestions };
    setScore(nextScore);
    setQuestionChecked(true);
    setQuestionFeedback({ status: feedbackStatus, title, desc });

    if (student.isAuthenticated) {
      syncProgressToSheets(nextScore, currentIndex, student);
    }
  };

  // --- Navigation & Progress Triggers ---
  const handleNextExercise = () => {
    if (currentIndex < exercises.length - 1) {
      const nextIndex = currentIndex + 1;
      setCurrentIndex(nextIndex);
      if (student.isAuthenticated) {
        syncProgressToSheets(score, nextIndex, student);
      }
    } else {
      showToast("¡Has llegado al final de los 100 ejercicios!", "success");
    }
  };

  const handlePrevExercise = () => {
    if (currentIndex > 0) {
      const prevIndex = currentIndex - 1;
      setCurrentIndex(prevIndex);
      if (student.isAuthenticated) {
        syncProgressToSheets(score, prevIndex, student);
      }
    } else {
      showToast("Estás en el primer ejercicio.", "info");
    }
  };

  const syncProgressToSheets = async (
    updatedScore: ScoreState,
    updatedIndex: number,
    updatedStudent: StudentProfile
  ) => {
    if (!updatedStudent.isAuthenticated) return;

    const grammarCorrectCount = Object.values(updatedScore.grammar).filter(v => v === true).length;
    const questionsCorrectCount = Object.values(updatedScore.questions).filter(v => v === true).length;

    const shadowingVals = Object.values(updatedScore.shadowing);
    let shadowingAvg = 0;
    if (shadowingVals.length > 0) {
      const total = (shadowingVals as number[]).reduce((acc: number, curr: number) => acc + curr, 0);
      shadowingAvg = Math.round(total / shadowingVals.length);
    }

    const payload = {
      fecha: new Date().toLocaleString("es-ES"),
      Fecha: new Date().toLocaleString("es-ES"),
      email: updatedStudent.email,
      Email: updatedStudent.email,
      nombre: updatedStudent.name,
      Nombre: updatedStudent.name,
      gramatica: `${grammarCorrectCount} / ${exercises.length}`,
      Gramatica: `${grammarCorrectCount} / ${exercises.length}`,
      preguntas: `${questionsCorrectCount} / ${exercises.length}`,
      Preguntas: `${questionsCorrectCount} / ${exercises.length}`,
      shadowing: `${shadowingAvg}%`,
      Shadowing: `${shadowingAvg}%`,
      progreso: `${updatedIndex + 1} de ${exercises.length} completados`,
      Progreso: `${updatedIndex + 1} de ${exercises.length} completados`
    };

    setIsSyncing(true);
    try {
      const res = await fetch("/api/sync", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        showToast("¡Progreso guardado en la nube con éxito!", "success");
      } else {
        showToast("Progreso guardado localmente.", "info");
      }
    } catch (error) {
      console.error("Error syncing to Google Sheets:", error);
      showToast("Guardado localmente de forma segura.", "info");
    } finally {
      setIsSyncing(false);
    }
  };

  // --- Cloud Sync ---
  const handleManualSync = () => {
    if (!student.isAuthenticated) {
      showToast("Identifícate primero para guardar tu progreso en la planilla del profesor.", "warning");
      setShowLoginModal(true);
      return;
    }
    syncProgressToSheets(score, currentIndex, student);
  };

  // --- Auth Modal handlers ---
  const handleManualLoginSave = (e: FormEvent) => {
    e.preventDefault();
    if (!manualName.trim() || !manualEmail.trim()) {
      showToast("Nombre y correo electrónico son requeridos.", "warning");
      return;
    }

    const updatedStudent = {
      name: manualName,
      email: manualEmail,
      isAuthenticated: true
    };

    setStudent(updatedStudent);
    localStorage.setItem("studentName", manualName);
    localStorage.setItem("studentEmail", manualEmail);
    setShowLoginModal(false);

    showToast(`¡Hola, ${manualName}! Registro local exitoso.`, "success");

    // Push initial sync immediately
    syncProgressToSheets(score, currentIndex, updatedStudent);
  };

  const handleLogout = () => {
    const confirmed = window.confirm("¿Seguro que deseas desvincular tus datos?");
    if (!confirmed) return;

    setStudent({
      name: "Estudiante Invitado",
      email: "invitado@aula.com",
      isAuthenticated: false
    });
    localStorage.removeItem("studentName");
    localStorage.removeItem("studentEmail");
    showToast("Datos de alumno desvinculados del navegador.", "info");
  };

  const handleResetConfirm = () => {
    setCurrentIndex(0);
    const cleanScore: ScoreState = { grammar: {}, questions: {}, shadowing: {} };
    setScore(cleanScore);
    setShowResetModal(false);
    showToast("Todo el progreso ha sido reiniciado.", "info");

    if (student.isAuthenticated) {
      syncProgressToSheets(cleanScore, 0, student);
    }
  };

  // --- Get overall score displays ---
  const grammarCorrectCount = Object.values(score.grammar).filter(v => v === true).length;
  const questionsCorrectCount = Object.values(score.questions).filter(v => v === true).length;

  const shadowingVals = Object.values(score.shadowing);
  let shadowingAvg = 0;
  if (shadowingVals.length > 0) {
    const total = (shadowingVals as number[]).reduce((acc: number, curr: number) => acc + curr, 0);
    shadowingAvg = Math.round(total / shadowingVals.length);
  }

  const progressPercentage = exercises.length > 0 ? ((currentIndex + 1) / exercises.length) * 100 : 0;
  const currentEx = exercises[currentIndex];

  return (
    <div className="min-h-screen flex flex-col font-sans text-slate-800 dark:text-slate-100 bg-slate-50 dark:bg-slate-950 transition-colors duration-200">
      
      {/* HEADER / NAVIGATION */}
      <header className="bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 sticky top-0 z-40 shadow-sm transition-colors duration-200 h-20">
